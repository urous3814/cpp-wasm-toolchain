{
  "name": "cpp-wasm-toolchain",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "bootstrap": "./toolchain/scripts/bootstrap-macos.sh",
    "build:sysroot": "./toolchain/scripts/build-sysroot.sh",
    "build:llvm-host": "./toolchain/scripts/build-host-llvm.sh",
    "build:llvm-browser": "./toolchain/scripts/build-browser-llvm.sh",
    "package": "./toolchain/scripts/package-toolchain.sh",
    "test": "./toolchain/scripts/smoke-test.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke-test:ci": "node tests/smoke/runtime-smoke.mjs",
    "demo:build": "mkdir -p demo/dist && tsc demo/main.ts --outDir demo/dist --target ES2020 --module ES2020 --moduleResolution bundler --strict --skipLibCheck && cp demo/index.html demo/dist/ && cp demo/style.css demo/dist/"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
