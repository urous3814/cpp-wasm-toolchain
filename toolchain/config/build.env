WASM_TARGET=wasm32-wasi
CMAKE_BUILD_TYPE=MinSizeRel
PARALLEL_JOBS=$(nproc 2>/dev/null || sysctl -n hw.logicalcpu)

# Host LLVM — minimal, only tablegen tools
HOST_LLVM_COMPONENTS="llvm-tblgen clang-tblgen"
HOST_LLVM_PROJECTS="clang"

# Browser LLVM — no debug, no tests, no threads
BROWSER_LLVM_PROJECTS="clang;lld"
BROWSER_LLVM_TARGETS="WebAssembly"
BROWSER_LLVM_DISABLE="LLVM_INCLUDE_TESTS;LLVM_INCLUDE_EXAMPLES;LLVM_ENABLE_THREADS"
